# ============================================================
# Chicago Crime + Divvy Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is gitignored — your secrets never enter version control.
# Compose reads .env automatically at `docker compose up`.
# ============================================================


# ============ Docker Compose ============
# Fixed project name so network/volume names are predictable.
# Without this, Compose derives the name from the folder name.
# Network: chicago-data-pipeline_default
# Volumes: chicago-data-pipeline_postgres_data, etc.
COMPOSE_PROJECT_NAME=chicago-data-pipeline


# ============ Postgres — Analytics Warehouse ============
# This is your data warehouse. Spark writes raw crime data here,
# DBT reads raw and writes marts here.
#
# POSTGRES_USER    — the database superuser (created on first init)
# POSTGRES_PASSWORD — must be set; Postgres refuses to start without it
# POSTGRES_DB      — the default database created on first init
# POSTGRES_PORT    — host-side port mapping (5432 is default; change if occupied)
POSTGRES_USER=chicago
POSTGRES_PASSWORD=chicago1234
POSTGRES_DB=chicago_analytics
POSTGRES_PORT=5432


# ============ Postgres — Airflow Metadata DB ============
# Airflow needs its OWN database to track DAG runs, task states,
# scheduling info, and logs. This is NOT your analytics data.
#
# If you point Airflow at chicago_analytics, it will create its own
# tables (task_instance, dag_run, etc.) and pollute your warehouse.
#
# These credentials are used in init.sql to create a separate database
# and user for Airflow within the same Postgres instance.
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_pass
AIRFLOW_DB_NAME=airflow_metadata


# ============ Airflow 3.0 Configuration ============
# EXECUTOR — how Airflow runs tasks:
#   SequentialExecutor — one task at a time (dev only, no parallelism)
#   LocalExecutor      — parallel tasks on one machine (Phase 1 fit)
#   CeleryExecutor     — distributed across worker machines (needs Redis/RabbitMQ)
#
# We use LocalExecutor: parallelism without extra containers.
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Don't load Airflow's example DAGs — they clutter the UI
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Airflow 3.0 API server port (host-side)
# Airflow 3.0 change: `airflow webserver` is GONE, replaced by `airflow api-server`.
# The web UI is now served by the API server. Config moved from [webserver] to [api].
AIRFLOW__API__PORT=8080

# ============ Airflow 3.0 Authentication ============
# Airflow 3.0 replaces Flask-AppBuilder (FAB) with SimpleAuthManager.
# This is a breaking change from 2.x:
#   - `airflow users create` CLI command is GONE
#   - Users are defined via env vars, not database-backed
#   - Passwords are stored in a JSON file (airflow/passwords.json)
#
# SIMPLE_AUTH_MANAGER_USERS — comma-separated list of username:role pairs
# Roles: viewer, user, op, admin
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=admin:admin

# Passwords file — mounted into container at /opt/airflow/config/passwords.json
# Format: {"username": "password"}
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_PASSWORDS_FILE=/opt/airflow/config/passwords.json

# Internal API secret key — shared between webserver and scheduler for
# mutual auth (DAG serialization). Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__CORE__INTERNAL_API_SECRET_KEY=generate_a_random_hex_string_here

# JWT secret — shared between webserver and scheduler for execution API auth.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API_AUTH__JWT_SECRET=generate_a_random_hex_string_here

# Webserver secret key — shared for session signing.
AIRFLOW__WEBSERVER__SECRET_KEY=generate_a_random_hex_string_here

# Docker socket GID — must match host for docker.sock access from Airflow.
# Find yours with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=1001


# ============ Socrata API (Chicago Crime Data) ============
# Socrata is the open data platform behind Chicago's data portal.
# An app token increases your API rate limit (from 1000 to 10000 req/hr).
# Register at: https://data.cityofchicago.org/profile/edit/developer_settings
SOCRATA_APP_TOKEN=your_app_token_here

# API Key — for authenticated Socrata access (Phase 2+ may need this)
SOCRATA_API_KEY_ID=your_api_key_id_here
SOCRATA_API_KEY_SECRET=your_api_key_secret_here

# Secret Token — paired with App Token for OAuth flows
SOCRATA_SECRET_TOKEN=your_secret_token_here
