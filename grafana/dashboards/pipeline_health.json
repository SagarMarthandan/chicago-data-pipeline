            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "success": {
                        "color": "green",
                        "index": 0
                      },
                      "failed": {
                        "color": "red",
                        "index": 1
                      },
                      "running": {
                        "color": "blue",
                        "index": 2
                      },
                      "up_for_retry": {
                        "color": "orange",
                        "index": 3
                      },
                      "upstream_failed": {
                        "color": "red",
                        "index": 4
                      }
                    },
                    "type": "value"
                  }
