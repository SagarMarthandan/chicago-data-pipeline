    {
      "datasource": {
        "type": "postgres",
        "uid": "chicago-analytics"
      },
      "description": "DBT test outcomes from the latest dbt build. Sourced from observability.dbt_test_results, written by the record_dbt_results Airflow task after every `dbt build` (Phase 3.2). passing = tests with status 'pass'; failing = status 'fail'; warnings = status 'warn'. If the panel shows no data, no dbt build has been recorded yet \u2014 trigger crime_batch or divvy_stream.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "failing"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "displayName",
                "value": "Failing"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "passing"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "displayName",
                "value": "Passing"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warnings"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Warnings"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
