          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT dag_id, task_id, run_id, state, start_date, end_date, EXTRACT(EPOCH FROM (end_date - start_date)) AS duration_seconds FROM task_instance WHERE start_date > NOW() - INTERVAL '2 days' ORDER BY start_date DESC LIMIT 50;",
          "refId": "A"
