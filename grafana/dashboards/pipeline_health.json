      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "chicago-analytics"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  count(*) FILTER (WHERE status = 'pass') AS passing,\n  count(*) FILTER (WHERE status = 'fail') AS failing,\n  count(*) FILTER (WHERE status = 'warn') AS warnings\nFROM observability.dbt_test_results\nWHERE generated_at = (SELECT max(generated_at) FROM observability.dbt_test_results);",
          "refId": "A"
        }
      ],
      "title": "DBT test outcomes (latest run)",
      "type": "stat"
    },
