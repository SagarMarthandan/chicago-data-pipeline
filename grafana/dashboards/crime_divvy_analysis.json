        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "chicago-analytics"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH crime_monthly AS (SELECT date_trunc('month', occurred_at) AS time, COUNT(*) AS monthly_crime_count FROM mart.fact_crime_events GROUP BY 1), trips_monthly AS (SELECT date_trunc('month', started_at) AS time, COUNT(*) AS monthly_trip_count FROM mart.fact_divvy_trips GROUP BY 1) SELECT c.time, c.monthly_crime_count, COALESCE(t.monthly_trip_count, 0) AS monthly_trip_count FROM crime_monthly c LEFT JOIN trips_monthly t ON c.time = t.time ORDER BY c.time;",
          "refId": "A"
        }
      ],
      "title": "Crime vs Divvy trips (monthly)",
      "type": "timeseries"
    },
