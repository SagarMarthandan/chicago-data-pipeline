        {
          "datasource": {
            "type": "postgres",
            "uid": "chicago-analytics"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH busy_stations AS (SELECT station_id FROM mart.fact_station_reads GROUP BY station_id ORDER BY COUNT(*) DESC LIMIT 20) SELECT EXTRACT(HOUR FROM reported_at)::int AS hour_of_day, station_id, AVG(num_bikes_available) AS avg_bikes FROM mart.fact_station_reads WHERE station_id IN (SELECT station_id FROM busy_stations) GROUP BY hour_of_day, station_id ORDER BY station_id, hour_of_day;",
          "refId": "A"
        }
      ],
      "title": "Station availability heatmap (top 20 stations × hour)",
      "type": "heatmap"
