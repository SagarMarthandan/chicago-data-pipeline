          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH busy_stations AS (SELECT start_station_id AS station_id FROM mart.fact_divvy_trips GROUP BY start_station_id ORDER BY COUNT(*) DESC LIMIT 20) SELECT EXTRACT(HOUR FROM started_at)::int AS hour_of_day, start_station_id AS station_id, COUNT(*) AS trip_count FROM mart.fact_divvy_trips WHERE start_station_id IN (SELECT station_id FROM busy_stations) GROUP BY hour_of_day, station_id ORDER BY station_id, hour_of_day;",
          "refId": "A"
        }
      ],
      "title": "Trip count heatmap (top 20 stations \u00d7 hour)",
      "type": "heatmap"
