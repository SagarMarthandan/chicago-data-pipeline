      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "chicago-analytics"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH crime_monthly AS (SELECT date_trunc('month', occurred_at) AS time, COUNT(*) AS monthly_crime_count FROM mart.fact_crime_events GROUP BY 1), bikes_monthly AS (SELECT date_trunc('month', reported_at) AS time, AVG(num_bikes_available) AS avg_bikes_available FROM mart.fact_station_reads GROUP BY 1) SELECT c.time, c.monthly_crime_count, COALESCE(b.avg_bikes_available, 0) AS avg_bikes_available FROM crime_monthly c LEFT JOIN bikes_monthly b ON c.time = b.time ORDER BY c.time;",
          "refId": "A"
        }
      ],
      "title": "Crime vs Divvy ridership proxy (monthly)",
      "type": "timeseries"
