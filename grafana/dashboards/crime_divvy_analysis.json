          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ca.community_area_name, COUNT(*) AS crime_count FROM mart.fact_crime_events f JOIN mart.dim_community_area ca ON f.community_area_id = ca.community_area_id WHERE f.community_area_id != 0 GROUP BY ca.community_area_name ORDER BY crime_count DESC LIMIT 15;",
